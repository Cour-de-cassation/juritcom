### Pour désactiver la coloration des logs
### NO_COLOR=true 

PORT=3010

### Minio 
S3_BUCKET_NAME_PDF=juritcom-archive-pdf
DELETION_COLLECTION_NAME=juritcom-deletion
S3_URL=http://localhost:9000
## to docker use host.docker.internal over localhost
S3_ACCESS_KEY=local_access_key
S3_SECRET_KEY=local_secret_key
S3_REGION=eu-west-paris-1

### DOC à adapter les valeurs
DOC_LOGIN=xxx
DOC_PASSWORD=xxx

### USE_AUTH = basic | jwt
USE_AUTH='basic'

## JWT
JWT_CLIENT_ID='xxx'
JWT_CLIENT_SECRET='xxx'
JWT_SECRET= # To fill with a strong random value (by running `openssl rand -hex 32` for example)
JWT_ISSUER=juritcom-dev
JWT_ACCEPTED_ISSUERS=juritcom-dev,juritcom-test
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=900 # 15 minutes

## to docker use host.docker.internal over localhost
FILE_DB_URL=mongodb://localhost:55433/rawFiles