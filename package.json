{
  "name": "juritcom",
  "version": "0.0.1",
  "description": "JURITCOM",
  "author": "Cour de Cassation",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier \"src/**/*.ts\" --check",
    "start": "ts-node src/server.ts",
    "start:watch": "nodemon --watch 'src/**' --ext 'ts,json' --exec 'npx ts-node src/server.ts'",
    "start:prod": "node dist/server.js",
    "start:docker": "docker compose up -d",
    "stop:docker": "docker compose stop",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "test": "jest && npm run test:integration",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --passWithNoTests --config ./jest-integration.json --runInBand",
    "fix": "eslint \"src/**/*.ts\" --fix && prettier \"src/**/*.ts\" --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1050.0",
    "axios": "1.16.1",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongodb": "7.2.0",
    "multer": "2.1.1",
    "nestjs-pino": "4.6.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "uuid": "11.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@smithy/util-stream": "4.6.3",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.9",
    "@types/multer": "2.1.0",
    "@types/node": "24.10.9",
    "@types/supertest": "6.0.3",
    "@types/uuid": "11.0.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "dotenv": "17.4.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.4.2",
    "jest-mock-extended": "4.0.1",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.10",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/.jest/setupEnvVars.ts"
    ]
  }
}