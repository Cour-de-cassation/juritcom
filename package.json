{
  "name": "juritcom",
  "version": "0.0.1",
  "description": "JURITCOM",
  "author": "Cour de Cassation",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier \"src/**/*.ts\" --check",
    "start": "NODE_ENV=local nest start",
    "start:watch": "NODE_ENV=local nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/api/main",
    "start:docker": "docker compose up -d",
    "stop:docker": "docker compose stop",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --quiet",
    "test": "jest && npm run test:integration",
    "test:api": "jest --testPathPattern=src/api & npm run test:integration",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:integration": "jest --passWithNoTests --config ./jest-integration.json --runInBand",
    "fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix && prettier \"src/**/*.ts\" --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1050.0",
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.21",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.21",
    "@nestjs/platform-express": "11.1.21",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.3",
    "@nestjs/terminus": "11.1.1",
    "@types/multer": "2.1.0",
    "axios": "1.16.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cron": "4.4.0",
    "dbsder-api-types": "3.0.3",
    "express-basic-auth": "1.2.1",
    "joi": "18.2.1",
    "jsonwebtoken": "9.0.3",
    "multer": "2.1.1",
    "mongodb": "7.2.0",
    "nestjs-pino": "4.6.1",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "rxjs": "7.8.2",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.21",
    "@smithy/util-stream": "4.6.3",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.9",
    "@types/supertest": "7.2.0",
    "@types/uuid": "11.0.0",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.4.2",
    "jest-mock-extended": "4.0.1",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.10",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.2",
    "typescript-eslint": "8.59.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/.jest/setupEnvVars.ts"
    ]
  }
}